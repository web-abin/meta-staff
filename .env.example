# --- server ---
SERVER_PORT=8080
SERVER_ENV=dev

# --- database ---
# 留空（或 memory://）= 内存模式，零依赖，每次重启数据清空，适合 demo
# 接入 Postgres17+pgvector 则填入连接串
POSTGRES_USER=meta
POSTGRES_PASSWORD=meta
POSTGRES_DB=meta_staff
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# DATABASE_URL=postgres://meta:meta@localhost:5432/meta_staff?sslmode=disable
DATABASE_URL=

# --- LLM ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# --- web ---
NEXT_PUBLIC_API_BASE=http://localhost:8080

# --- notify (optional) ---
# 飞书 / Lark 群机器人 webhook；任务上线后推送交互卡片，留空则跳过。
FEISHU_WEBHOOK_URL=
